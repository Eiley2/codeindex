[index]
# Optional: defaults to folder name if omitted
name = "my_project"
# Optional: per-project embedding model override
# (fallback order: CLI flag > this value > global config/env > default)
embedding_provider = "local"  # "local" or "openrouter"
embedding_model = "sentence-transformers/all-MiniLM-L6-v2"
include_patterns = ["*.py", "*.md"]
# Important: this replaces default excludes entirely.
# Keep node_modules/.venv/caches excluded to avoid slow indexing.
exclude_patterns = [
  "node_modules/**",
  ".git/**",
  ".venv/**",
  "venv/**",
  "env/**",
  ".tox/**",
  ".nox/**",
  "build/**",
  "dist/**",
  ".next/**",
  "__pycache__/**",
  ".mypy_cache/**",
  ".pytest_cache/**",
  ".ruff_cache/**",
  "*.min.js",
  "*.lock",
  "*.map",
]
# Optional: used when --reset is not provided
reset = false
# Optional safeguards for large repos
max_files = 20000
max_file_bytes = 5000000

[chunking]
chunk_size = 1000
chunk_overlap = 300
min_chunk_size = 300
